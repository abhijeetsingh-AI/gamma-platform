# ════════════════════════════════════════════════
# GAMMA PLATFORM — .env.example
# Copy to .env and fill ALL values
# ════════════════════════════════════════════════

# ── Deepgram STT (READY) ──────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Gemini LLM (READY) ────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Twilio (READY) ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_WEBHOOK_URL=https://YOUR-RENDER-URL/api/voice/incoming

# ── TTS Provider ──────────────────────────────
# "twilio" = use Twilio <Say> voice — works immediately, no GCP needed
# "google" = use Google Neural2 — requires GOOGLE_APPLICATION_CREDENTIALS
TTS_PROVIDER=twilio

# ── Google Cloud TTS (add later) ──────────────
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# ── App / Security ────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
BASE_URL=YOUR-RENDER-URL-HERE    # e.g. gamma-api.onrender.com (no https://)
DATABASE_URL=sqlite+aiosqlite:///./gamma.db
UPLOAD_DIR=./uploads

# ── Redis (Celery) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0
